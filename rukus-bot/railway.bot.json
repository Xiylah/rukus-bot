{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install --frozen-lockfile=false && pnpm --filter @rukus/db exec prisma generate"
  },
  "deploy": {
    "startCommand": "pnpm --filter @rukus/bot start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
