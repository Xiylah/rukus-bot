# ============================================================
# Rukus Bot - environment variables
# Copy this file to `.env` and fill in real values.
# The .env file is git-ignored; never commit real secrets.
# ============================================================

# ============================================================
# The BOT (Railway, Node.js) uses Prisma → the Postgres connection strings.
# The DASHBOARD (Cloudflare Pages, edge) uses the Supabase JS client → the
# REST URL + keys. Both talk to the same database, different doors.
# ============================================================

# ---- Database for the BOT (Prisma / Postgres) ----
# Supabase → Connect → Connection string. Use the POOLER, not the direct host!
#
#   ✅ aws-N-<region>.pooler.supabase.com   (has IPv4 - works everywhere)
#   ❌ db.<projectref>.supabase.co          (IPv6-ONLY - fails on Railway with
#                                            "Can't reach database server")
#
# Railway containers have no IPv6 egress, so the direct host is unreachable from
# there even though it works from a home connection. Always use the pooler.
#
#   DATABASE_URL -> Transaction pooler, port 6543 (app queries)
#   DIRECT_URL   -> Session pooler,     port 5432 (migrations / DDL)
#
# Note the username includes the project ref: postgres.<projectref>
DATABASE_URL="postgresql://postgres.PROJECTREF:PASSWORD@aws-N-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.PROJECTREF:PASSWORD@aws-N-REGION.pooler.supabase.com:5432/postgres"

# ---- Database for the DASHBOARD (Supabase JS / PostgREST, edge-compatible) ----
# Supabase → Project Settings → API.
# SUPABASE_URL is the project URL, e.g. https://ycsygssnegqrvtdnbpzk.supabase.co
SUPABASE_URL="https://PROJECTREF.supabase.co"
# The service_role key (Settings → API → Project API keys → service_role).
# It bypasses row-level security - it is a SECRET, server-only, never shipped
# to the browser. The dashboard's server code has already authenticated the
# admin via Discord OAuth before using it.
SUPABASE_SERVICE_ROLE_KEY=""

# ---- Discord bot ----
# Discord Developer Portal → your application → Bot → Reset Token.
DISCORD_BOT_TOKEN=""
# Developer Portal → General Information → Application ID.
DISCORD_CLIENT_ID=""
# Your Rukus server ID (right-click server → Copy Server ID, dev mode on).
DISCORD_GUILD_ID="700382994946588814"

# ---- Discord OAuth (dashboard login) ----
# Developer Portal → OAuth2 → Client ID / Client Secret.
# Can be the SAME application as the bot above.
DISCORD_CLIENT_SECRET=""

# ---- Dashboard (Next.js / Auth.js) ----
# Base URL of the dashboard. In dev: http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# ---- Translation (optional) ----
# DeepL gives higher-quality translations (esp. French). Leave blank to use
# Google only. Get a free key at https://www.deepl.com/pro-api
DEEPL_API_KEY=""
