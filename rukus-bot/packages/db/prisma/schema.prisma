// Prisma schema for the Rukus bot + dashboard.
//
// IMPORTANT: this database is SHARED with another app (a Roblox game whose
// tables live in the `public` schema - leaderboard, saves, ratings, etc.).
// To keep the two completely isolated, ALL bot tables live in their own
// dedicated `rukus` Postgres schema. Prisma only ever manages `rukus`, so it
// can never touch or drop the game's `public` tables.
//
// Design note: every table that holds per-server data carries `guildId`. Today
// the bot runs for a single guild, but keying everything by guild means the
// jump to a multi-server (public) bot is a data change, not a rewrite.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["rukus"]
}

/// One row per guild the bot is in. Holds top-level metadata; feature config
/// lives in FeatureConfig so the dashboard can update features independently.
model Guild {
  id        String   @id // Discord guild snowflake
  name      String?
  iconHash  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  features    FeatureConfig[]
  tickets     Ticket[]
  submissions FormSubmission[]

  @@schema("rukus")
}

/// JSON config blob for a single feature (tickets, forms, ...) in a guild.
/// Shape is validated by the Zod schemas in @rukus/shared on both read/write.
model FeatureConfig {
  id      String  @id @default(cuid())
  guild   Guild   @relation(fields: [guildId], references: [id], onDelete: Cascade)
  guildId String
  feature String // "tickets" | "forms" | "moderation"
  /// Validated JSON matching the feature's Zod schema.
  config  Json    @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([guildId, feature])
  @@index([guildId])
  @@schema("rukus")
}

enum TicketStatus {
  OPEN
  CLAIMED
  CLOSED

  @@schema("rukus")
}

/// A support ticket. The Discord channel is created/closed by the bot; this row
/// is the source of truth for status, ownership, and the transcript pointer.
model Ticket {
  id        String       @id @default(cuid())
  guild     Guild        @relation(fields: [guildId], references: [id], onDelete: Cascade)
  guildId   String
  /// Sequential per-guild number shown to users (ticket-0001).
  number    Int
  channelId String       @unique
  openerId  String // user who opened it
  claimedBy String? // staff who claimed it
  status    TicketStatus @default(OPEN)
  subject   String?
  /// Ticket type id from the guild's ticket config, so close-time logic can
  /// resolve per-type settings (transcript channel etc.) reliably.
  typeId    String?
  /// Public URL of the hosted transcript once closed.
  transcriptUrl String?
  /// Unguessable token the dashboard serves the transcript under.
  transcriptToken String? @unique
  /// The transcript HTML itself, served by the dashboard's /transcript route.
  transcriptHtml String?

  createdAt DateTime  @default(now())
  closedAt  DateTime?

  /// Two-way conversation translation: the opener's language code (e.g.
  /// "fr"). Staff messages get translated to it, opener messages to the
  /// guild's target language. Null = mode off.
  translateLang String?
  /// Post-close satisfaction rating from the opener (1-5 stars).
  rating        Int?

  /// Staff opted this ticket out of inactivity auto-close.
  autoCloseDisabled   Boolean   @default(false)
  /// When the inactivity warning was posted (null = not warned).
  autoCloseWarnedAt   DateTime?
  /// Id of the warning message, to detect activity after the warning.
  autoCloseWarnedMsgId String?

  @@unique([guildId, number])
  @@index([guildId, status])
  @@index([openerId])
  @@schema("rukus")
}

/// Counter table so ticket numbers are sequential and race-free per guild.
model TicketCounter {
  guildId String @id
  next    Int    @default(1)

  @@schema("rukus")
}

enum CaseAction {
  WARN
  TIMEOUT
  UNTIMEOUT
  MUTE
  UNMUTE
  KICK
  BAN
  UNBAN

  @@schema("rukus")
}

/// One moderation action = one numbered case, forming a user's record.
model ModCase {
  id          String     @id @default(cuid())
  guildId     String
  /// Sequential per-guild case number shown to staff (#0001).
  number      Int
  action      CaseAction
  /// The member the action was taken against.
  userId      String
  userTag     String?
  moderatorId String
  reason      String?
  /// Timeout length in minutes, when applicable.
  durationMin Int?
  /// Proof image: stored as base64 so it outlives Discord's expiring CDN
  /// links, served by the dashboard at /proof/<token>.
  proofToken       String? @unique
  proofData        String?
  proofContentType String?
  createdAt   DateTime   @default(now())

  @@unique([guildId, number])
  @@index([guildId, userId])
  @@index([guildId, createdAt])
  @@schema("rukus")
}

/// Race-free per-guild case numbering.
model CaseCounter {
  guildId String @id
  next    Int    @default(1)

  @@schema("rukus")
}

/// A freeform staff note about a member. Unlike a ModCase this is not a
/// punishment: it is context ("history of ban evasion", "was helpful in #x")
/// that staff leave for each other. Pure data, so no config schema.
model UserNote {
  id       String   @id @default(cuid())
  guildId  String
  userId   String
  authorId String
  note     String   @db.Text
  createdAt DateTime @default(now())

  @@index([guildId, userId])
  @@schema("rukus")
}

enum SubmissionStatus {
  PENDING
  APPROVED
  DENIED

  @@schema("rukus")
}

/// A completed form/application submission awaiting or past review.
model FormSubmission {
  id       String           @id @default(cuid())
  guild    Guild            @relation(fields: [guildId], references: [id], onDelete: Cascade)
  guildId  String
  formId   String // matches a form id inside the forms FeatureConfig
  formName String
  userId   String
  /// Array of { label, value } captured from the modal, stored as JSON.
  answers  Json
  status   SubmissionStatus @default(PENDING)
  reviewedBy String?
  reviewNote String?
  /// The review-channel message id, so approve/deny can edit it in place.
  reviewMessageId String?

  createdAt  DateTime  @default(now())
  reviewedAt DateTime?

  @@index([guildId, status])
  @@index([userId])
  @@schema("rukus")
}

/// A message that crossed the star threshold and got mirrored to the board.
/// Keyed by the SOURCE message so a second star on an already-posted message
/// updates the existing board post instead of creating a duplicate.
model StarboardPost {
  id                 String   @id @default(cuid())
  guildId            String
  sourceMessageId    String   @unique
  sourceChannelId    String
  /// The message we posted in the starboard channel, so we can edit the count.
  starboardMessageId String
  authorId           String
  starCount          Int      @default(0)
  createdAt          DateTime @default(now())

  @@index([guildId])
  @@schema("rukus")
}

/// A member's XP/level progress in one guild.
model MemberLevel {
  id       String   @id @default(cuid())
  guildId  String
  userId   String
  xp       Int      @default(0)
  level    Int      @default(0)
  messages Int      @default(0)
  /// Minutes spent in voice that earned XP, shown on the rank card.
  voiceMinutes Int  @default(0)
  /// Last time XP was awarded, for the per-message cooldown.
  lastXpAt DateTime @default(now())

  @@unique([guildId, userId])
  /// Serves the leaderboard: top XP within a guild, without a full scan.
  @@index([guildId, xp])
  @@schema("rukus")
}

/// Snapshot of a member's roles, taken when they leave, so autoroles can hand
/// them back on rejoin. One row per member: the latest snapshot wins.
model MemberRoleBackup {
  id        String   @id @default(cuid())
  guildId   String
  userId    String
  roleIds   String[]
  updatedAt DateTime @updatedAt

  @@unique([guildId, userId])
  @@schema("rukus")
}

/// A pending /remind. The scheduler polls by dueAt.
model Reminder {
  id        String   @id @default(cuid())
  guildId   String
  userId    String
  channelId String
  text      String
  dueAt     DateTime
  /// Null = one-shot. Set = reschedule this many seconds after firing.
  repeatSec Int?
  createdAt DateTime @default(now())

  @@index([dueAt])
  @@index([guildId, userId])
  @@schema("rukus")
}

/// One word a member wants to be DM'd about when it's said in the guild.
model Highlight {
  id        String   @id @default(cuid())
  guildId   String
  userId    String
  word      String
  createdAt DateTime @default(now())

  @@unique([guildId, userId, word])
  @@index([guildId])
  @@schema("rukus")
}

/// A running or finished giveaway. The message is the entry surface, so it is
/// the natural unique key when a reaction comes in.
model Giveaway {
  id             String   @id @default(cuid())
  guildId        String
  channelId      String
  messageId      String   @unique
  hostId         String
  prize          String
  winnerCount    Int      @default(1)
  endsAt         DateTime
  ended          Boolean  @default(false)
  /// Everyone who pressed Enter. Kept on the row so a reroll after the giveaway
  /// ends does not depend on the Discord message still existing.
  entrantIds     String[]
  winnerIds      String[]
  /// Only members with this role may enter. Null = anyone.
  requiredRoleId String?
  createdAt      DateTime @default(now())

  /// The scheduler's query: giveaways past their end time that haven't ended.
  @@index([endsAt, ended])
  @@index([guildId])
  @@schema("rukus")
}

enum SuggestionStatus {
  PENDING
  APPROVED
  DENIED
  CONSIDERED
  IMPLEMENTED

  @@schema("rukus")
}

/// A member suggestion, numbered per guild so staff can refer to "#12".
model Suggestion {
  id        String           @id @default(cuid())
  guildId   String
  number    Int
  channelId String
  messageId String
  authorId  String
  text      String
  status    SuggestionStatus @default(PENDING)
  /// Staff's public explanation for the decision.
  reason    String?
  staffId   String?
  createdAt DateTime         @default(now())

  @@unique([guildId, number])
  @@index([guildId, status])
  @@schema("rukus")
}

/// Race-free per-guild suggestion numbering.
model SuggestionCounter {
  guildId String @id
  next    Int    @default(1)

  @@schema("rukus")
}

/// A member's active AFK status. One row per member; cleared when they talk.
model Afk {
  id      String   @id @default(cuid())
  guildId String
  userId  String
  message String
  since   DateTime @default(now())

  @@unique([guildId, userId])
  @@schema("rukus")
}

/// A member's birthday in one guild. Year is optional because plenty of people
/// will happily share the day but not their age.
model Birthday {
  id        String   @id @default(cuid())
  guildId   String
  userId    String
  day       Int
  month     Int
  year      Int?
  createdAt DateTime @default(now())

  @@unique([guildId, userId])
  /// The daily sweep's query: everyone whose birthday is today.
  @@index([guildId, month, day])
  @@schema("rukus")
}

/// One join attributed to an inviter. Rows, not a counter, so a leaver can be
/// discounted and a suspicious burst of invites can be inspected.
model InviteUse {
  id           String   @id @default(cuid())
  guildId      String
  inviterId    String
  joinedUserId String
  code         String
  createdAt    DateTime @default(now())

  @@index([guildId, inviterId])
  @@schema("rukus")
}

/// A personal voice channel created from the temp-voice lobby. Deleted with the
/// channel when it empties.
model TempVoice {
  id        String   @id @default(cuid())
  guildId   String
  channelId String   @unique
  ownerId   String
  createdAt DateTime @default(now())

  @@index([guildId])
  @@schema("rukus")
}

/// A user-created TagScript tag, recalled by name.
model Tag {
  id        String   @id @default(cuid())
  guildId   String
  name      String
  content   String
  ownerId   String
  uses      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([guildId, name])
  @@index([guildId])
  @@schema("rukus")
}

/// A photo/video contest. Entries are messages posted in `channelId` while the
/// contest is running; votes are reactions counted when it ends.
model Contest {
  id          String   @id @default(cuid())
  guildId     String
  /// Where entries are posted and auto-detected. A contest can run across
  /// several channels at once (photos in one, videos in another), so this is a
  /// list; the first entry is where the announcement is posted.
  channelIds  String[]
  /// The announcement message, so it can be edited live with the countdown.
  messageId   String?  @unique
  hostId      String
  title       String
  description String   @default("")
  /// How many places are awarded (1 = winner only, 3 = 1st/2nd/3rd).
  winnerCount Int      @default(3)
  endsAt      DateTime
  ended       Boolean  @default(false)
  /// Resolved at the end and kept on the row, so results survive the entry
  /// messages being deleted afterwards.
  winnerIds   String[]
  createdAt   DateTime @default(now())

  entries ContestEntry[]

  /// The scheduler's query: contests past their end time that have not ended.
  @@index([endsAt, ended])
  @@index([guildId])
  @@schema("rukus")
}

/// One submitted image/video. `votes` is a snapshot taken when the contest
/// ends; live counts are read from Discord.
model ContestEntry {
  id        String   @id @default(cuid())
  contest   Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)
  contestId String
  guildId   String
  /// Which of the contest's channels this entry was posted in. Needed to fetch
  /// the message back when counting votes across several channels.
  channelId String
  /// The member's message holding the image or video.
  messageId String   @unique
  userId    String
  /// Direct link to the media, kept so results can still show it if the
  /// original message is deleted.
  mediaUrl  String   @default("")
  votes     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([contestId])
  @@index([guildId, userId])
  @@schema("rukus")
}
